# AI provider (OpenAI-compatible endpoint)
# Default: Google AI Studio OpenAI-compatible endpoint
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
AI_MODEL=gemini-3.5-flash

# Set one of these keys. AI_API_KEY has highest priority.
AI_API_KEY=
GEMINI_API_KEY=your-gemini-api-key-here
OPENROUTER_API_KEY=

# AI request controls
AI_TEMPERATURE=0.5
AI_TIMEOUT=180
AI_MAX_TOKENS=16384
AI_MAX_INPUT_CHARS=32000

# Notion integration token
NOTION_TOKEN=ntn_your_notion_integration_token_here

# Notion database ID (the target database for saving articles)
NOTION_DATABASE_ID=your_notion_database_id_here

# RSS and HTTP controls
MAX_ENTRIES=100
RSS_SUMMARY_MAX_CHARS=600
FETCH_TIMEOUT=30
HTTP_TIMEOUT=30
HTTP_RETRIES=3
NOTIFY_TIMEOUT=10

# Push key for ServerChan notifications
PUSH_KEY=your_push_key_here
