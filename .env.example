# OpenRouter API key (used for AI summary via OpenAI-compatible API)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Notion integration token
NOTION_TOKEN=ntn_your_notion_integration_token_here

# Notion database ID (the target database for saving articles)
NOTION_DATABASE_ID=your_notion_database_id_here

# Push key for mobile notifications (e.g., PushPlus / WxPusher)
PUSH_KEY=your_push_key_here
